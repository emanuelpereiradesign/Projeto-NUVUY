# Supabase
SUPABASE_URL=SUA_SUPABASE_URL_AQUI
SUPABASE_ANON_KEY=SUA_SUPABASE_ANON_KEY_AQUI

# Google Maps API (scraper principal)
GOOGLE_MAPS_API_KEY=SUA_GOOGLE_MAPS_API_KEY_AQUI

# Google Custom Search API (scraper Instagram - opcional)
# Crie um Programmable Search Engine em https://programmablesearchengine.google.com/
# e uma API Key em https://console.cloud.google.com/apis/credentials
GOOGLE_API_KEY=SUA_GOOGLE_API_KEY_AQUI
GOOGLE_CX=SEU_GOOGLE_CX_AQUI

# OpenRouter (classificação IA)
OPENROUTER_API_KEY=SEU_OPENROUTER_API_KEY_AQUI
OPENROUTER_MODEL=openrouter/free

# MisticPay (pagamentos)
MISTICPAY_CI=SEU_MISTICPAY_CI_AQUI
MISTICPAY_CS=SEU_MISTICPAY_CS_AQUI
FRONTEND_URL=http://localhost:5500
BACKEND_URL=http://localhost:3000
